generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  role          String   @default("ADMIN")
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  logoUrl      String?
  primaryColor String   @default("#14f1cc")
  accentColor  String   @default("#14f1cc")
  timezone     String   @default("America/Chicago")
  domain       String?
  events       Event[]
  settings     Setting?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Event {
  id                       String      @id @default(cuid())
  organizationId           String
  organization             Organization @relation(fields: [organizationId], references: [id])
  name                     String
  description              String
  venue                    String
  address                  String
  startsAt                 DateTime
  endsAt                   DateTime
  capacity                 Int
  photoUrl                 String?
  bannerImageUrl           String?
  logoUrl                  String?
  allergenOptions          String?
  organizer                String
  contactEmail             String
  contactPhone             String?
  status                   String      @default("DRAFT")
  registrationEnabled      Boolean     @default(true)
  qrPassesEnabled          Boolean     @default(true)
  emailConfirmationsEnabled Boolean    @default(true)
  waitlistEnabled          Boolean     @default(false)
  registrationDeadline     DateTime?
  attendees                Attendee[]
  emailLogs                EmailLog[]
  rafflePrizes             RafflePrize[]
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
}

model Attendee {
  id                 String             @id @default(cuid())
  eventId            String
  event              Event              @relation(fields: [eventId], references: [id])
  firstName          String
  lastName           String
  email              String
  phone              String?
  company            String?
  birthDate          DateTime?
  selectedAllergens  String?
  plusOneEnabled     Boolean            @default(false)
  plusOneFirstName   String?
  plusOneLastName    String?
  plusOneBirthDate   DateTime?
  plusOneAllergens   String?
  under21            Boolean            @default(false)
  plusOneUnder21     Boolean            @default(false)
  ticketTier         String             @default("General")
  seat               String?
  vip                Boolean            @default(false)
  raffleTickets      Int                @default(0)
  notes              String?
  customAnswers      String?
  status             String             @default("REGISTERED")
  pass               Pass?
  checkIns           CheckIn[]
  raffleEntries      RaffleEntry[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([eventId, email])
  @@index([eventId, status])
}

model Pass {
  id           String   @id @default(cuid())
  attendeeId   String   @unique
  attendee     Attendee @relation(fields: [attendeeId], references: [id])
  fallbackCode String   @unique
  qrPayload    String
  tokenHash    String
  pdfUrl       String?
  createdAt    DateTime @default(now())
}

model CheckIn {
  id          String   @id @default(cuid())
  attendeeId  String
  attendee    Attendee @relation(fields: [attendeeId], references: [id])
  scannedById String?
  scannedAt   DateTime @default(now())
  duplicate   Boolean  @default(false)
  rawPayload   String?
}

model EmailLog {
  id          String      @id @default(cuid())
  eventId     String
  event       Event       @relation(fields: [eventId], references: [id])
  attendeeId  String?
  recipient   String
  type        String
  subject     String
  providerId  String?
  status      String      @default("QUEUED")
  error       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model RafflePrize {
  id          String        @id @default(cuid())
  eventId     String
  event       Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  description String?
  value       String?
  imageUrl    String?
  status      String        @default("ACTIVE")
  winnerName  String?
  drawnAt     DateTime?
  entries     RaffleEntry[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([eventId, status])
}

model RaffleEntry {
  id          String       @id @default(cuid())
  prizeId     String
  prize       RafflePrize  @relation(fields: [prizeId], references: [id], onDelete: Cascade)
  attendeeId  String
  attendee    Attendee     @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  ticketCount Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([prizeId, attendeeId])
  @@index([attendeeId])
}

model Setting {
  id             String       @id @default(cuid())
  organizationId String      @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  smtpHost       String?
  smtpPort       Int?
  smtpUser       String?
  smtpFrom       String?
  defaultTimezone String      @default("America/Chicago")
  apiKeyHash      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}
