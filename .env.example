DATABASE_URL="file:./dev.db"
# Docker Compose overrides DATABASE_URL with this persistent container path.
DOCKER_DATABASE_URL="file:/app/data/eventpass.db"
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
APP_URL="http://localhost:3000"
QR_SIGNING_SECRET="replace-with-a-long-random-secret"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe123!"
SKIP_SEED="false"
CLOUDFLARE_TUNNEL_TOKEN=""
# Use "console" for local development or "resend" for real delivery.
EMAIL_PROVIDER="console"
EMAIL_FROM="EventPass <passes@yourdomain.com>"
RESEND_API_KEY=""
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
